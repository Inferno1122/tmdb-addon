{
  "version": 2,
  "builds": [
    { "src": "addon/server.js", "use": "@vercel/node" },
    { "src": "package.json",   "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "rewrites": [
    { "source": "/api/:path*",       "destination": "/addon/server.js" },
    { "source": "/configure/:path*", "destination": "/dist/:path*" },
    { "source": "/configure",        "destination": "/dist/index.html" },
    { "source": "/:path*",           "destination": "/dist/:path*" }
  ]
}
