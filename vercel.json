{
  "version": 2,
  "public": "dist",
  "rewrites": [
    { "source": "/configure", "destination": "/index.html" },
    { "source": "/configure/:path*", "destination": "/:path*" },
    
    { "source": "/manifest.json", "destination": "/addon/server.js" },
    { "source": "/catalog/:path*", "destination": "/addon/server.js" },
    { "source": "/meta/:path*", "destination": "/addon/server.js" },
    { "source": "/stream/:path*", "destination": "/addon/server.js" },
    
    { "source": "/addon/:path*", "destination": "/addon/server.js" },
    { "source": "/:path*", "destination": "/addon/server.js" }
  ]
}
