{
  "version": 2,
  "builds": [
    { "src": "addon/server.js", "use": "@vercel/node" },
    { "src": "configure/dist/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/manifest.json", "dest": "/addon/server.js" },
    { "src": "/catalog/.*", "dest": "/addon/server.js" },
    { "src": "/meta/.*", "dest": "/addon/server.js" },
    { "src": "/stream/.*", "dest": "/addon/server.js" },

    { "src": "/configure", "dest": "/configure/dist/index.html" },
    { "src": "/configure/(.*)", "dest": "/configure/dist/$1" },

    { "src": "/.*", "dest": "/addon/server.js" }
  ]
}
